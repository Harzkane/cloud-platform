# ══════════════════════════════════════════
#   NexGenHost — Environment Variables
#   Copy to .env and fill in real values
# ══════════════════════════════════════════

# ── APP ─────────────────────────────────
NODE_ENV=development
PORT=3000

# ── DATABASE (PostgreSQL) ────────────────
DATABASE_URL=postgresql://ngx_user:ngx_secret@localhost:5432/nexgenhost_dev

# ── REDIS (Queue + Cache) ────────────────
REDIS_URL=redis://localhost:6379

# ── AUTH ─────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# ── PAYSTACK (Billing) ───────────────────
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx
PAYSTACK_WEBHOOK_SECRET=your_paystack_webhook_secret

# ── GITHUB (Auto-deploy) ─────────────────
GITHUB_WEBHOOK_SECRET=your_github_webhook_secret
# Optional: GitHub App credentials for private repos
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=

# ── DASHBOARD ────────────────────────────
DASHBOARD_URL=http://localhost:3001
API_URL=http://localhost:3000

# ── WORKER (Go) ──────────────────────────
WORKER_API_CALLBACK_URL=http://localhost:3000/internal
WORKER_REDIS_URL=redis://localhost:6379
WORKER_DEPLOY_QUEUE=nexgenhost:deployments
WORKER_WORK_DIR=/tmp/nexgenhost/builds

# ── CLOUDFLARE (DNS + CDN) ───────────────
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_DOMAIN=nexgenhost.com

# ── STORAGE (S3-compatible, optional) ────
STORAGE_ENDPOINT=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_BUCKET=nexgenhost-artifacts
